{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genposter V3",
  "version": "0.1.0",
  "identifier": "com.riviu.genposter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @genposter/desktop dev",
    "beforeBuildCommand": "pnpm --filter @genposter/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genposter V3",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
